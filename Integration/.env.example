# Integration harness configuration (all read from the process environment;
# scripts/run-local.mjs fills in these defaults automatically).

# REQUIRED. The private server the suite may touch. There is deliberately no
# default inside the test code: pointing this at screeps.com is refused.
SCREEPS_PRIVATE_HOST=http://127.0.0.1:21025

# Server CLI (launcher default). Host defaults to the API host's hostname.
#SCREEPS_CLI_HOST=127.0.0.1
SCREEPS_CLI_PORT=21026

# Tick duration the harness configures on the server (ms). Faster = quicker
# suite; 100–200 is sensible on developer hardware.
SCREEPS_TICK_MS=150

# Test account the harness creates (CLI) and signs in with (bridge).
#SCREEPS_TEST_USER=itester
#SCREEPS_TEST_PASSWORD=itester-secret

# Scenario H part 2: how to restart the server process. Leave unset to skip
# that sub-test (e.g. when running against a non-docker private server).
SCREEPS_RESTART_CMD=docker compose restart screeps

# Set true only if your private server is on a non-private-range host.
#SCREEPS_ALLOW_REMOTE=true

# Optional real Steam API key for the launcher (harness never needs it).
#STEAM_KEY=
