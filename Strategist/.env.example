# ── AI Strategist configuration (all optional; sensible safe defaults) ──────────

# ── Screeps bridge (the strategist owns its own connection) ─────────────────────
# Same variables the bridge/UI use. Reads ColonyState, writes Directives only.
SCREEPS_SERVER=official
SCREEPS_TOKEN=
SCREEPS_SHARD=shard3
# Private-server overrides — ONLY uncomment when SCREEPS_SERVER=private.
# (Leaving SCREEPS_HOST set on an "official" server would point it at localhost.)
# SCREEPS_HOST=http://localhost:21025
# SCREEPS_USERNAME=
# SCREEPS_PASSWORD=

# ── Strategist service ──────────────────────────────────────────────────────────
# HTTP API the UI commander panel talks to.
STRATEGIST_PORT=4100

# Which decider drives strategy: "rules" (default, no API cost) | "ollama" (LLM).
DECIDER=rules

# Safety: dry-run logs decisions WITHOUT writing directives (default on).
# Kill switch halts ALL writing; the colony stays fully autonomous.
DRY_RUN=true
KILL_SWITCH=false

# Write budget: directive writes ride POST memory (~240/day). Cap per hour.
MAX_WRITES_PER_HOUR=6

# Cadence: never evaluate more often than this; slow fallback re-eval interval.
MIN_EVAL_INTERVAL_MS=60000
SLOW_TICK_MS=300000

# Consecutive evals with a non-advancing executor heartbeat before "stalled".
STALL_EVAL_THRESHOLD=3

# Decision history kept in memory for the UI.
HISTORY_MAX=200

# Rule-decider thresholds.
MIN_STORED_ENERGY_FOR_EXPAND=50000
BUCKET_FLOOR=2000
PLATEAU_STORAGE_ENERGY=100000
MAX_UPGRADER_QUOTA=8
# Comma-separated rooms the rule decider may pick as expand targets.
EXPAND_CANDIDATES=

# ── Ollama (only used when DECIDER=ollama) ──────────────────────────────────────
# Mode A (default): direct cloud API — no local daemon, key in the Authorization header.
# Mode B: a local Ollama signed into the cloud account -> OLLAMA_HOST=http://localhost:11434
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=kimi-k2.6:cloud
OLLAMA_API_KEY=
OLLAMA_RETRIES=2
