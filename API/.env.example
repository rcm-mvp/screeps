# Screeps Web API Bridge configuration (all optional; can also be passed to the constructor)

# Server preset: "official" | "ptr" | "private"
SCREEPS_SERVER=official

# Persistent auth token (generate once at https://screeps.com/a/#!/account/auth-tokens)
SCREEPS_TOKEN=

# Default shard for shard-scoped calls
SCREEPS_SHARD=shard3

# Private-server overrides (only when SCREEPS_SERVER=private)
SCREEPS_HOST=http://localhost:21025
# Optional plain username/password signin for private servers without tokens
SCREEPS_USERNAME=
SCREEPS_PASSWORD=

# Toggle structured request/response logging ("true" | "false")
SCREEPS_LOG=false
